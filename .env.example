# ═══════════════════════════════════════════════════════════════════════
# NeoTrace Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────────
# Security Configuration
# ───────────────────────────────────────────────────────────────────────

# API Key for protecting sensitive endpoints (e.g., for internal use)
# Generate: openssl rand -hex 32
API_KEY=your_secret_api_key_here

# CORS: Comma-separated list of allowed origins for cross-origin requests
# Default allows localhost (dev) and https://neotrace.vercel.app (production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3010,https://neotrace.vercel.app

# ───────────────────────────────────────────────────────────────────────
# Third-party API Keys
# ───────────────────────────────────────────────────────────────────────

# ASI-1 AI API Key - for AI-powered features (chatbot, content generation, etc.)
# Get from: https://api.asi1.ai
# Features that use this key:
# - Chatbot conversation
# - Content generation for game scenarios
# - Text summary enhancement
# - Stats generation
ASI_API_KEY=your_asi_api_key_here

# ASI Model to use
ASI_MODEL=asi1-mini

# Phone number verification (Numverify) - optional feature
# Get from: https://numverify.com
NUMVERIFY_KEY=your_numverify_key_here

# ───────────────────────────────────────────────────────────────────────
# Deployment Platform
# ───────────────────────────────────────────────────────────────────────

# Set automatically by Vercel; indicates serverless deployment
# VERCEL=1

# ═══════════════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env file to git - it contains secrets!
#    .env is already in .gitignore
#
# 2. For production on Vercel:
#    - Go to your project settings
#    - Navigate to "Environment Variables"
#    - Add each variable (API_KEY, ASI_API_KEY, etc.)
#
# 3. For local development:
#    - Copy .env.example to .env
#    - Fill in your API keys
#    - Run: npm run dev
#
# 4. Rotate API keys periodically for security
#
# 5. Never expose API keys in frontend code - keep them server-side
#
# 6. Use strong, random API_KEY values (32+ hex characters)
#    Generate: openssl rand -hex 32
#
# ═══════════════════════════════════════════════════════════════════════
